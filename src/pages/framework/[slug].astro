---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import FrameworkSection from '../../layouts/FrameworkSection.astro';

export async function getStaticPaths() {
	const sections = (await getCollection('framework')).sort(
		(a, b) => a.data.order - b.data.order,
	);
	return sections.map((section, index) => ({
		params: { slug: section.id },
		props: {
			section,
			prev: index > 0
				? { slug: sections[index - 1].id, title: sections[index - 1].data.title }
				: undefined,
			next: index < sections.length - 1
				? { slug: sections[index + 1].id, title: sections[index + 1].data.title }
				: undefined,
		},
	}));
}

type Props = {
	section: CollectionEntry<'framework'>;
	prev?: { slug: string; title: string };
	next?: { slug: string; title: string };
};

const { section, prev, next } = Astro.props;
const { Content } = await render(section);
---

<FrameworkSection {...section.data} prev={prev} next={next}>
	<Content />
</FrameworkSection>
