---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = (await getCollection('blog')).sort(
		(a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf(),
	);
	return posts.map((post, index) => ({
		params: { slug: post.id },
		props: {
			post,
			prev: index > 0
				? { id: posts[index - 1].id, title: posts[index - 1].data.title }
				: undefined,
			next: index < posts.length - 1
				? { id: posts[index + 1].id, title: posts[index + 1].data.title }
				: undefined,
		},
	}));
}

type Props = {
	post: CollectionEntry<'blog'>;
	prev?: { id: string; title: string };
	next?: { id: string; title: string };
};

const { post, prev, next } = Astro.props;
const { Content } = await render(post);

// Estimate reading time (~220 wpm for reflective literary content)
const wordCount = post.body?.split(/\s+/).filter(Boolean).length ?? 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 220));
---

<BlogPost {...post.data} readingTime={readingTime} prev={prev} next={next}>
	<Content />
</BlogPost>
