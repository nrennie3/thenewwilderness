---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const articles = (await getCollection('framework')).sort(
	(a, b) => a.data.order - b.data.order,
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Articles — ${SITE_TITLE}`}
			description="A collection of articles on faith, family, and resilience in the age of artificial intelligence."
		/>
		<style>
			main {
				max-width: 720px;
				margin: 0 auto;
				padding: 3rem 1.25rem 5rem;
			}
			h1 {
				font-size: clamp(1.8rem, 4vw, 2.4rem);
				margin: 0 0 2.5rem 0;
				line-height: 1.15;
			}
			.article-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.article-item {
				border-bottom: 1px solid var(--rule);
			}
			.article-item a {
				display: flex;
				align-items: flex-start;
				gap: 1.25rem;
				padding: 1.5rem 0.25rem;
				text-decoration: none;
				transition: background 0.15s;
			}
			.article-item a:hover .article-title {
				color: var(--accent);
			}
			.article-body {
				flex: 1;
				min-width: 0;
			}
			.article-title {
				font-family: "Playfair Display", Georgia, serif;
				font-size: 1.15rem;
				font-weight: 700;
				color: rgb(var(--black));
				margin: 0 0 0.3rem 0;
				line-height: 1.3;
				transition: color 0.15s;
			}
			.article-desc {
				font-family: "Inter", Georgia, serif;
				font-size: 0.88rem;
				color: rgb(var(--gray));
				margin: 0;
				line-height: 1.55;
			}
			.article-arrow {
				color: var(--accent);
				font-size: 1rem;
				opacity: 0;
				transition: opacity 0.15s;
				padding-top: 0.15rem;
				flex-shrink: 0;
			}
			.article-item a:hover .article-arrow {
				opacity: 1;
			}
			@media (max-width: 600px) {
				main {
					padding: 2rem 1rem 4rem;
				}
				.article-arrow {
					opacity: 1;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Articles</h1>
			<ol class="article-list">
				{articles.map((article) => (
					<li class="article-item">
						<a href={`/articles/${article.id}/`}>
							<div class="article-body">
								<h2 class="article-title">{article.data.title}</h2>
								{article.data.description && (
									<p class="article-desc">{article.data.description}</p>
								)}
							</div>
							<div class="article-arrow">→</div>
						</a>
					</li>
				))}
			</ol>
		</main>
		<Footer />
	</body>
</html>
