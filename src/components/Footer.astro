---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-rule"></div>
		<p class="footer-copy">&copy; {today.getFullYear()} The New Wilderness. All rights reserved.</p>
	</div>
</footer>

<style>
	footer {
		background: var(--cream);
		margin-top: 4rem;
		padding: 0;
	}
	.footer-inner {
		max-width: 860px;
		margin: 0 auto;
		padding: 0 1rem 2.5rem;
	}
	.footer-rule {
		height: 1px;
		background: var(--rule);
		margin-bottom: 1.5rem;
	}
	.footer-copy {
		text-align: center;
		font-family: "Inter", Georgia, serif;
		font-size: 0.8rem;
		color: rgb(var(--gray));
		margin: 0;
	}
</style>
