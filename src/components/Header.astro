---
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<div class="masthead">
		<div class="masthead-inner">
			<div class="brand">
				<a href="/" class="site-title">{SITE_TITLE}</a>
				<p class="tagline">{SITE_DESCRIPTION}</p>
			</div>
			<nav>
				<HeaderLink href="/">Home</HeaderLink>
				<span class="sep" aria-hidden="true">·</span>
				<HeaderLink href="/articles">Articles</HeaderLink>
			</nav>
		</div>
		<div class="bottom-rule"></div>
	</div>
</header>

<style>
	header {
		background: var(--cream);
		margin: 0;
		padding: 0;
	}
	.masthead {
		max-width: 860px;
		margin: 0 auto;
		padding: 0 1.25rem;
	}
	.masthead-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		padding: 1.5rem 0 1.25rem;
	}
	.brand {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}
	.site-title {
		font-family: "Playfair Display", Georgia, serif;
		font-size: 1.6rem;
		font-weight: 700;
		color: rgb(var(--black));
		text-decoration: none;
		line-height: 1;
		letter-spacing: -0.01em;
	}
	.site-title:hover {
		color: var(--accent);
	}
	.tagline {
		font-family: "Inter", sans-serif;
		font-size: 0.78rem;
		color: rgb(var(--gray));
		margin: 0;
		letter-spacing: 0.01em;
	}
	nav {
		display: flex;
		align-items: center;
		gap: 0.2rem;
		flex-shrink: 0;
	}
	nav a {
		font-family: "Inter", sans-serif;
		font-size: 0.78rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: rgb(var(--gray-dark));
		text-decoration: none;
		padding: 0.2rem 0.5rem;
		transition: color 0.15s;
	}
	nav a:hover {
		color: var(--accent);
	}
	nav a.active {
		color: var(--accent);
		font-weight: 600;
	}
	.sep {
		color: rgb(var(--gray));
		font-size: 0.75rem;
		user-select: none;
	}
	.bottom-rule {
		height: 1px;
		background: var(--rule);
	}
	@media (max-width: 500px) {
		.tagline {
			display: none;
		}
		.site-title {
			font-size: 1.3rem;
		}
	}
</style>
