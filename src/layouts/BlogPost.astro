---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	readingTime?: number;
	prev?: { id: string; title: string };
	next?: { id: string; title: string };
};

const { title, description, pubDate, updatedDate, heroImage, readingTime, prev, next } = Astro.props;

// Extract series label from titles like "Vignette #1: The Provision"
const seriesMatch = title.match(/^Vignette #(\d+):/i);
const seriesNum = seriesMatch ? seriesMatch[1] : null;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
				padding: 0;
			}
			.post-header {
				max-width: 680px;
				margin: 0 auto;
				padding: 3rem 1rem 2rem;
				text-align: center;
			}
			.series-label {
				display: inline-block;
				font-family: "Lora", Georgia, serif;
				font-size: 0.72rem;
				font-weight: 600;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: var(--accent);
				margin-bottom: 1.5rem;
				text-decoration: none;
			}
			.header-rule {
				height: 1px;
				background: var(--rule);
				margin: 1.5rem 0;
			}
			.post-header h1 {
				font-family: "Playfair Display", Georgia, serif;
				font-size: 2.6rem;
				line-height: 1.2;
				margin: 0;
				color: rgb(var(--black));
			}
			.post-meta {
				display: flex;
				justify-content: center;
				align-items: center;
				flex-wrap: wrap;
				gap: 0.4rem 0.8rem;
				font-family: "Lora", Georgia, serif;
				font-size: 0.85rem;
				color: rgb(var(--gray));
				font-style: italic;
			}
			.post-meta .meta-sep {
				font-style: normal;
				color: rgb(var(--gray-light));
			}
			.hero-image {
				width: 100%;
				margin-bottom: 2rem;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 8px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 680px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 0 1em 3em;
				color: rgb(var(--gray-dark));
				font-size: 1.05rem;
				line-height: 1.9;
			}
			.prose :global(p) {
				margin-bottom: 1.75em;
			}
			.prose :global(h2),
			.prose :global(h3) {
				margin-top: 2.5rem;
				margin-bottom: 0.75rem;
			}
			.post-nav {
				width: 680px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 2rem 1em 4em;
				display: flex;
				justify-content: space-between;
				gap: 1.5rem;
				border-top: 1px solid var(--rule);
			}
			.post-nav-link {
				text-decoration: none;
				max-width: 45%;
			}
			.post-nav-label {
				font-family: "Lora", Georgia, serif;
				font-size: 0.68rem;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				display: block;
				margin-bottom: 0.35rem;
			}
			.post-nav-title {
				font-family: "Playfair Display", Georgia, serif;
				font-size: 0.95rem;
				color: rgb(var(--black));
				transition: color 0.15s;
				display: block;
				line-height: 1.35;
			}
			.post-nav-link:hover .post-nav-title {
				color: var(--accent);
			}
			.post-nav-next {
				text-align: right;
				margin-left: auto;
			}
			@media (max-width: 720px) {
				.post-header {
					padding: 2rem 1rem 1.5rem;
				}
				.post-header h1 {
					font-size: 1.9rem;
				}
				.post-nav {
					flex-direction: column;
					gap: 1.5rem;
				}
				.post-nav-next {
					text-align: left;
					margin-left: 0;
				}
				.post-nav-link {
					max-width: 100%;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="post-header">
					{seriesNum && (
						<a class="series-label" href="/blog">
							The Christian Resilience Framework &nbsp;·&nbsp; Vignette #{seriesNum}
						</a>
					)}
					<div class="header-rule"></div>
					<h1>{title}</h1>
					<div class="header-rule"></div>
					<div class="post-meta">
						<FormattedDate date={pubDate} />
						{readingTime && (
							<>
								<span class="meta-sep">·</span>
								<span>{readingTime} min read</span>
							</>
						)}
						{updatedDate && (
							<>
								<span class="meta-sep">·</span>
								<span>Updated <FormattedDate date={updatedDate} /></span>
							</>
						)}
					</div>
				</div>

				{heroImage && (
					<div class="hero-image">
						<Image width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}

				<div class="prose">
					<slot />
				</div>
			</article>

			{(prev || next) && (
				<nav class="post-nav" aria-label="Post navigation">
					{prev && (
						<a class="post-nav-link" href={`/blog/${prev.id}/`}>
							<span class="post-nav-label">← Previous</span>
							<span class="post-nav-title">{prev.title}</span>
						</a>
					)}
					{next && (
						<a class="post-nav-link post-nav-next" href={`/blog/${next.id}/`}>
							<span class="post-nav-label">Next →</span>
							<span class="post-nav-title">{next.title}</span>
						</a>
					)}
				</nav>
			)}
		</main>
		<Footer />
	</body>
</html>
