---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description?: string;
	order: number;
	slug: string;
	date?: string;
}

const { title, description, slug, date } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead
			title={`${title} — The New Wilderness`}
			description={description ?? 'An article from The New Wilderness.'}
		/>
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 0;
			}
			.article-header {
				max-width: 860px;
				margin: 0 auto;
				padding: 1rem 1.25rem 0;
			}
			.breadcrumb {
				font-family: "Inter", sans-serif;
				font-size: 0.72rem;
				font-weight: 600;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				text-decoration: none;
				display: inline-block;
				margin-bottom: 0.6rem;
				transition: color 0.15s;
			}
			.breadcrumb:hover {
				color: var(--accent);
			}
			.header-rule {
				height: 1px;
				background: var(--rule);
				margin: 1.5rem 0;
			}
			.article-header h1 {
				font-family: "Playfair Display", Georgia, serif;
				font-size: clamp(1.75rem, 4vw, 2.4rem);
				line-height: 1.2;
				margin: 0;
				color: rgb(var(--black));
			}
			.prose {
				max-width: 860px;
				margin: 0 auto;
				padding: 0 1.25rem 3rem;
				color: rgb(var(--gray-dark));
				font-size: 1.03rem;
				line-height: 1.9;
			}
			.prose :global(p) {
				margin-bottom: 1.6em;
			}
			.prose :global(h2) {
				font-family: "Playfair Display", Georgia, serif;
				font-size: 1.65rem;
				margin-top: 3rem;
				margin-bottom: 0.6rem;
				padding-bottom: 0.4rem;
				border-bottom: 1px solid rgb(var(--gray-light));
				color: rgb(var(--black));
			}
			.prose :global(h3) {
				font-family: "Playfair Display", Georgia, serif;
				font-size: 1.2rem;
				margin-top: 2.25rem;
				margin-bottom: 0.5rem;
				color: rgb(var(--black));
			}
			.prose :global(h4) {
				font-size: 1rem;
				margin-top: 1.75rem;
				margin-bottom: 0.4rem;
			}
			.prose :global(ul),
			.prose :global(ol) {
				padding-left: 1.5em;
				margin-bottom: 1.5em;
			}
			.prose :global(li) {
				margin-bottom: 0.6em;
			}
			.prose :global(blockquote) {
				border-left: 3px solid var(--accent);
				padding: 0.75em 0 0.75em 1.5rem;
				margin: 2rem 0;
				font-style: italic;
				font-size: 0.97em;
				color: rgb(var(--gray));
				background: rgba(var(--gray-light), 0.25);
				border-radius: 0 6px 6px 0;
			}
			.prose :global(blockquote strong) {
				font-style: normal;
				color: rgb(var(--gray-dark));
			}
			.prose :global(hr) {
				border: none;
				border-top: 1px solid var(--rule);
				margin: 2.5rem 0;
			}
			.prose :global(strong) {
				color: rgb(var(--black));
			}
			.prose :global(em) {
				font-style: italic;
			}
			.article-footer {
				max-width: 860px;
				margin: 0 auto;
				padding: 1.25rem 1.25rem 1.5rem;
				border-top: 1px solid var(--rule);
			}
			@media (max-width: 720px) {
				.article-header {
					padding: 1.25rem 1.25rem 0;
				}
				.article-footer {
					padding: 1rem 1.25rem 1rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<div class="article-header">
				<a class="breadcrumb" href={`/articles#${slug}`}>← Articles</a>
				<h1>{title}</h1>
				<div class="header-rule"></div>
			</div>

			<div class="prose">
				<slot />
			</div>

			<div class="article-footer">
				<a class="breadcrumb" href={`/articles#${slug}`}>← Articles</a>
			</div>
		</main>
		<Footer lastUpdated={date} />
	</body>
</html>
